rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated users can read everything
    match /{document=**} {
      allow read: if request.auth != null;
    }

    // Authenticated users can write the shared chart data
    match /shared_charts/{chartId} {
      allow write: if request.auth != null;
    }

    // Only admins can add/delete/rename charts.
    match /app_config/charts_index {
      allow write: if request.auth != null && (
        request.auth.token.email == 'michael.kavalar@mtacd.org' ||
        (exists(/databases/$(database)/documents/app_config/user_roles) &&
         get(/databases/$(database)/documents/app_config/user_roles).data.roles[request.auth.token.email] == 'admin')
      );
    }

    // Only admins can write user roles.
    match /app_config/user_roles {
      allow write: if request.auth != null && (
        request.auth.token.email == 'michael.kavalar@mtacd.org' ||
        (resource != null && resource.data.roles[request.auth.token.email] == 'admin')
      );
    }
  }
}
